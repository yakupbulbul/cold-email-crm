# ============================================================
# AI-Powered Cold Email CRM — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit a populated .env file to version control.
# ============================================================

# --- Database ---
POSTGRES_URL=postgresql://user:password@db:5432/cold_email_crm

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- Security ---
# Generate a strong random key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-strong-random-string

# --- External APIs ---
OPENAI_API_KEY=

# --- Frontend ---
# Set to the public URL of the API for the Next.js build
NEXT_PUBLIC_API_URL=https://crm.example.com/api/v1
