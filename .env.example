# ============================================================
# AI-Powered Cold Email CRM — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit a populated .env file to version control.
# ============================================================

# --- Database ---
POSTGRES_URL=postgresql://user:password@db:5432/cold_email_crm

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- Security ---
# Generate a strong random key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-strong-random-string

# --- External APIs ---
OPENAI_API_KEY=

# --- Frontend ---
# Build-time API URL for Next.js (relative path recommended — always HTTPS-safe)
NEXT_PUBLIC_API_URL=/api/v1
# Server-side backend URL for Next.js rewrites (used in docker-compose)
BACKEND_URL=http://api:8000

# --- Mailcow API Integration ---
# Your Mailcow instance API URL (e.g., https://mail.example.com/api/v1)
MAILCOW_API_URL=
# Your Mailcow API Key (obtained from System -> API)
MAILCOW_API_KEY=
