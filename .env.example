# ============================================================
# AI-Powered Cold Email CRM — Local development environment
# ============================================================
# Copy this file to .env and fill in LOCAL values only.
# Keep real secrets and private endpoints out of git.
# Use your private local setup reference for real values.
# ============================================================

# --- App Runtime ---
APP_ENV=development
FRONTEND_PORT=3000
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8050
BACKEND_URL=http://127.0.0.1:8050
NEXT_PUBLIC_API_URL=/api/v1
ALLOWED_ORIGINS=http://localhost:3000

# --- Database / Redis ---
POSTGRES_PORT=55432
REDIS_PORT=56379
POSTGRES_URL=postgresql://user:password@127.0.0.1:55432/cold_email_crm
REDIS_URL=redis://127.0.0.1:56379/0

# --- Security ---
# Generate a strong random local secret:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-local-secret
ACCESS_TOKEN_EXPIRE_MINUTES=11520
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-local-admin-password

# --- Optional AI Integration ---
OPENAI_API_KEY=

# --- Remote Mailcow Integration ---
# These values are used by the backend only. The frontend must never call Mailcow directly.
MAILCOW_API_URL=https://mail.example.com/api/v1
MAILCOW_API_KEY=YOUR_API_KEY_HERE
MAILCOW_API_TIMEOUT_SECONDS=10
MAILCOW_VERIFY_SSL=true
MAILCOW_ENABLE_MUTATIONS=false

# Optional defaults for remote mailbox connectivity checks or mailbox creation forms.
MAILCOW_SMTP_HOST=mail.example.com
MAILCOW_SMTP_PORT=587
MAILCOW_IMAP_HOST=mail.example.com
MAILCOW_IMAP_PORT=993
